#include <Arduino.h>
#include <Wire.h>
#include <ArduinoBLE.h>
#include <Arduino_LSM9DS1.h>

//  ArmTracker: 3-IMU orientation tracking (quaternions via BLE)
//
//  Sensors:
//   0 = Internal LSM9DS1 (Shoulder)
//   1 = External MPU6050 = 0x69 (Wrist)
//   2 = External MPU6050 = 0x68 (Elbow)
//
//  Pipeline (every 20ms):
//   1) Read accel + gyro for each sensor
//   2) Run Madgwick filter to update quaternion
//   3) Pack quaternions into a BLE notification string


#define SAMPLE_RATE 50          // Intended loop rate ~50 Hz (20ms period)
#define BETA 0.05f              // Madgwick gain: smaller = smoother/slower correction, bigger = snappier/noisier

// BLE UUIDs (Nordic UART style service) 
#define SERVICE_UUID  "6E400001-B5A3-F393-E0A9-E50E24DCCA9E"
#define RX_UUID       "6E400002-B5A3-F393-E0A9-E50E24DCCA9E" // Write from central -> peripheral
#define TX_UUID       "6E400003-B5A3-F393-E0A9-E50E24DCCA9E" // Notify from peripheral -> central

BLEService uartService(SERVICE_UUID);

// TX: notify up to 255 bytes per packet (library limit depends on MTU; this is "max buffer")
BLECharacteristic txChar(TX_UUID, BLENotify, 255);

// RX: allow writing small commands (20 bytes is classic BLE default payload)
BLECharacteristic rxChar(RX_UUID, BLEWrite, 20);


//  Per-sensor state
//  - Quaternion (q0,q1,q2,q3) tracks orientation
//  - Gyro biases are estimated at boot (calibration)

struct Sensor {
    // Quaternion (w,x,y,z) -> here stored as q0,q1,q2,q3
    float q0 = 1, q1 = 0, q2 = 0, q3 = 0;

    // Gyroscope bias offsets (deg/s) to subtract each read
    float gxBias = 0, gyBias = 0, gzBias = 0;
};

// Array of 3 sensors: 0=internal, 1=MPU wrist, 2=MPU elbow
Sensor s[3];

void setupMPU(int addr) {
    // Wake up device (clear SLEEP bit)
    Wire.beginTransmission(addr);
    Wire.write(0x6B); 
    Wire.write(0x00);
    Wire.endTransmission();

    // Gyro config: FS_SEL = 3 -> ±2000 dps
    // Register 0x1B: bits[4:3] = 11b => 0x18
    Wire.beginTransmission(addr);
    Wire.write(0x1B); 
    Wire.write(0x18);
    Wire.endTransmission();

    // Accel config: AFS_SEL = 2 -> ±8g
    // Register 0x1C: bits[4:3] = 10b => 0x10
    Wire.beginTransmission(addr);
    Wire.write(0x1C); 
    Wire.write(0x10);
    Wire.endTransmission();
}


//  Read MPU6050 raw data and convert to engineering units
//  Reads 14 bytes starting at ACCEL_XOUT_H (0x3B):
//   - Accel XYZ (6 bytes)
//   - Temp      (2 bytes) [ignored]
//   - Gyro  XYZ (6 bytes)
//
//  Output:
//   ax,ay,az in g
//   gx,gy,gz in deg/s (then later converted to rad/s for filter)

void readMPU(int addr,
             float &ax, float &ay, float &az,
             float &gx, float &gy, float &gz) {

    // Set register pointer to 0x3B then do a repeated-start read
    Wire.beginTransmission(addr);
    Wire.write(0x3B);
    Wire.endTransmission(false);

    Wire.requestFrom(addr, 14);
    if (Wire.available() < 14) return;  // Safety: if bus glitches, skip this sample

    int16_t r[7]; // 7 words = 14 bytes
    for (int i = 0; i < 7; i++) {
        r[i] = (Wire.read() << 8) | Wire.read();
    }

    // Convert using chosen full-scale settings:
    // ±8g  => 4096 LSB per g
    ax = r[0] / 4096.0f;
    ay = r[1] / 4096.0f;
    az = r[2] / 4096.0f;

    // ±2000 dps => 16.4 LSB per deg/s
    gx = r[4] / 16.4f;
    gy = r[5] / 16.4f;
    gz = r[6] / 16.4f;
}


//  Madgwick filter update (IMU variant: accel + gyro)
//  - id selects which Sensor state to update
//  - gyro input expected in deg/s -> converted to rad/s internally
//  - accel normalized to unit gravity vector

void madgwick(int id,
              float ax, float ay, float az,
              float gx, float gy, float gz,
              float dt) {

    Sensor &sen = s[id];

    // Remove estimated gyro bias (calibrated at startup)
    gx -= sen.gxBias;
    gy -= sen.gyBias;
    gz -= sen.gzBias;

    // Convert deg/s -> rad/s (Madgwick equations use radians)
    const float rad = 0.0174533f;  // pi/180
    gx *= rad;
    gy *= rad;
    gz *= rad;

    // Local copy for readability/performance
    float q0 = sen.q0, q1 = sen.q1, q2 = sen.q2, q3 = sen.q3;

    // Normalize accelerometer (we only care about direction of gravity)
    float norm = sqrt(ax * ax + ay * ay + az * az);
    if (norm == 0.0f) return;      // Avoid divide-by-zero if accel read is garbage
    norm = 1.0f / norm;
    ax *= norm; ay *= norm; az *= norm;

    // Precompute repeated terms (classic Madgwick optimization)
    float _2q0 = 2.0f * q0, _2q1 = 2.0f * q1, _2q2 = 2.0f * q2, _2q3 = 2.0f * q3;
    float _4q0 = 4.0f * q0, _4q1 = 4.0f * q1, _4q2 = 4.0f * q2;
    float _8q1 = 8.0f * q1, _8q2 = 8.0f * q2;
    float q0q0 = q0 * q0, q1q1 = q1 * q1, q2q2 = q2 * q2, q3q3 = q3 * q3;

    // Gradient descent step (s0..s3) pulls quaternion toward matching accel gravity
    float s0 = _4q0 * q2q2 + _2q2 * ax + _4q0 * q1q1 - _2q1 * ay;
    float s1 = _4q1 * q3q3 - _2q3 * ax + 4.0f * q0q0 * q1 - _2q0 * ay
             - _4q1 + _8q1 * q1q1 + _8q1 * q2q2 + _4q1 * az;
    float s2 = 4.0f * q0q0 * q2 + _2q0 * ax + _4q2 * q3q3 - _2q3 * ay
             - _4q2 + _8q2 * q1q1 + _8q2 * q2q2 + _4q2 * az;
    float s3 = 4.0f * q1q1 * q3 - _2q1 * ax + 4.0f * q2q2 * q3 - _2q2 * ay;

    // Normalize the gradient step vector
    norm = 1.0f / sqrt(s0 * s0 + s1 * s1 + s2 * s2 + s3 * s3);
    s0 *= norm; s1 *= norm; s2 *= norm; s3 *= norm;

    // Quaternion derivative from gyro + correction from accel (beta * gradient)
    float qDot1 = 0.5f * (-q1 * gx - q2 * gy - q3 * gz) - BETA * s0;
    float qDot2 = 0.5f * ( q0 * gx + q2 * gz - q3 * gy) - BETA * s1;
    float qDot3 = 0.5f * ( q0 * gy - q1 * gz + q3 * gx) - BETA * s2;
    float qDot4 = 0.5f * ( q0 * gz + q1 * gy - q2 * gx) - BETA * s3;

    // Integrate to update quaternion
    q0 += qDot1 * dt;
    q1 += qDot2 * dt;
    q2 += qDot3 * dt;
    q3 += qDot4 * dt;

    // Renormalize quaternion to keep it unit-length (critical!)
    norm = 1.0f / sqrt(q0 * q0 + q1 * q1 + q2 * q2 + q3 * q3);
    sen.q0 = q0 * norm;
    sen.q1 = q1 * norm;
    sen.q2 = q2 * norm;
    sen.q3 = q3 * norm;
}


void setup() {
    Serial.begin(115200);

    Wire.begin();
    // Lower I2C clock can help stability with longer wires / noisy bus
    Wire.setClock(100000);

    // External sensor address mapping note:
    // If outputs seem swapped, you likely have the address mapping reversed.
    // Here: 0x69 is Wrist, 0x68 is Elbow.
    setupMPU(0x69); // Wrist
    setupMPU(0x68); // Elbow

    // Internal IMU init (LSM9DS1)
    if (!IMU.begin()) {
        Serial.println("Internal IMU Failed!");
        while (1);
    }

    // BLE init
    if (!BLE.begin()) {
        Serial.println("BLE Failed!");
        while (1);
    }

    // BLE advertising setup
    BLE.setLocalName("ArmTracker");
    BLE.setAdvertisedService(uartService);

    uartService.addCharacteristic(txChar);
    uartService.addCharacteristic(rxChar);
    BLE.addService(uartService);

    BLE.advertise();

    // --- Gyro bias calibration ---
    // We average gyro readings for each sensor and treat that average as "bias".
    // IMPORTANT: keep sensors completely still during this period.
    Serial.println("Calibrating... DO NOT MOVE.");

    float d[3][6];          // [sensor][0..2 accel, 3..5 gyro]
    int samples = 200;      // More samples = better bias estimate, slower boot

    for (int i = 0; i < samples; i++) {
        // Sensor 0: internal LSM9DS1 gyro
        if (IMU.gyroscopeAvailable()) {
            IMU.readGyroscope(d[0][3], d[0][4], d[0][5]);
        }

        // Sensor 1 & 2: external MPUs
        readMPU(0x69, d[1][0], d[1][1], d[1][2], d[1][3], d[1][4], d[1][5]);
        readMPU(0x68, d[2][0], d[2][1], d[2][2], d[2][3], d[2][4], d[2][5]);

        // Accumulate gyro bias sum
        for (int k = 0; k < 3; k++) {
            s[k].gxBias += d[k][3];
            s[k].gyBias += d[k][4];
            s[k].gzBias += d[k][5];
        }

        delay(5); // small delay to spread samples in time
    }

    // Convert sums to averages
    for (int k = 0; k < 3; k++) {
        s[k].gxBias /= samples;
        s[k].gyBias /= samples;
        s[k].gzBias /= samples;
    }

    Serial.println("Ready.");
}


long lastT = 0;


//  - BLE.poll() keeps BLE stack responsive
//  - Every 20ms read sensors, update filters, send BLE packet
void loop() {
    BLE.poll(); // required for ArduinoBLE to process connections/notifications

    // Run at ~50Hz based on millis() timing
    if (millis() - lastT >= 20) {
        // dt in seconds (float) for filter integration
        float dt = (millis() - lastT) / 1000.0f;
        lastT = millis();

        float d[3][6];

        // 1) Internal IMU (Shoulder / Sensor 0)
        // Guard with availability checks to avoid stale reads
        if (IMU.accelerationAvailable() && IMU.gyroscopeAvailable()) {
            IMU.readAcceleration(d[0][0], d[0][1], d[0][2]);
            IMU.readGyroscope(d[0][3], d[0][4], d[0][5]);
        }

        // 2) External MPUs (Wrist/Elbow)
        readMPU(0x69, d[1][0], d[1][1], d[1][2], d[1][3], d[1][4], d[1][5]);
        readMPU(0x68, d[2][0], d[2][1], d[2][2], d[2][3], d[2][4], d[2][5]);

        // 3) Update orientation estimate for each sensor
        for (int i = 0; i < 3; i++) {
            madgwick(i,
                     d[i][0], d[i][1], d[i][2],   // accel
                     d[i][3], d[i][4], d[i][5],   // gyro
                     dt);
        }

        // 4) Build BLE packet (string)
        // Format:
        //  ALL:q1,q2,q3,q0|q1,q2,q3,q0|q1,q2,q3,q0
        // Note: quaternion ordering here is x,y,z,w (q1,q2,q3,q0)
        // Be consistent with your receiving app/Unity/etc.
        String p = "ALL:";
        for (int i = 0; i < 3; i++) {
            p += String(s[i].q1, 3) + "," + String(s[i].q2, 3) + "," +
                 String(s[i].q3, 3) + "," + String(s[i].q0, 3);

            if (i < 2) p += "|";
        }
        p += "\n";

        // Notify connected central device (phone/PC/etc.)
        txChar.writeValue(p.c_str(), p.length());

        // Also print for debugging over USB Serial
        Serial.print(p);
    }
}
